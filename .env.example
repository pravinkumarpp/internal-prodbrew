# Supabase (required for auth and database)
NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY

# Optional
GEMINI_API_KEY
APP_URL

# Cron (optional; if set, cron check route requires this secret)
CRON_SECRET

# Fizzy Boards (optional; create a card when a task is submitted via the form)
FIZZY_ACCESS_TOKEN
FIZZY_ACCOUNT_ID
FIZZY_BOARD_ID


# Pricing Flow Landing
GITHUB_TOKEN
GITHUB_OWNER
GITHUB_REPO
GITHUB_BASE_BRANCH

# Automation middleware (optional override; defaults to http://localhost:3001/automation)
AUTOMATION_ENGINE_URL

# Per-client GitHub details (prefix is uppercased client name with spaces/symbols -> "_")
# Example: "Pricing Flow Landing" => PRICING_FLOW_LANDING_*
PRICING_FLOW_LANDING_GITHUB_TOKEN
PRICING_FLOW_LANDING_GITHUB_OWNER
PRICING_FLOW_LANDING_GITHUB_REPO


# Basecamp
BASECAMP_CLIENT_ID
BASECAMP_CLIENT_SECRET
REDIRECT_URI
BASECAMP_ACCESS_TOKEN
BASECAMP_REFRESH_TOKEN
BASECAMP_ACCOUNT_ID
BASECAMP_BASE_URL
BASECAMP_PROJECT_ID