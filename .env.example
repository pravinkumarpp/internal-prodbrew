# Supabase (required for auth and database)
NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY

# Optional
GEMINI_API_KEY
APP_URL

# Cron (optional; if set, cron check route requires this secret)
CRON_SECRET

# Fizzy Boards (optional; create a card when a task is submitted via the form)
FIZZY_ACCESS_TOKEN
FIZZY_ACCOUNT_ID
FIZZY_BOARD_ID
